# ============================================================
# MAESTRO 360 — Servidor WhatsApp (Evolution API)
# Copie este arquivo para .env e preencha os valores.
# ============================================================

# Porta onde este servidor Node.js escuta
# Nota: o deploy.yml usa PORT=3003 via PM2; este valor é usado como fallback
PORT=3003

# URL da Evolution API (porta mapeada no docker-compose)
EVO_URL=http://localhost:8090

# Chave de API da Evolution (definida em AUTHENTICATION_API_KEY no .env da Evolution)
EVO_API_KEY=SUA_CHAVE_AQUI

# Nome da instância WhatsApp dentro da Evolution API
EVO_INSTANCE=maestro360

# URL que a Evolution usará para enviar eventos a este servidor (deve ser acessível pela Evolution)
# Com Docker (recomendado): http://host.docker.internal:3003/webhook
# Em produção com NGINX:    https://seudominio.com.br/wpp/webhook
# Sem Docker (local):       http://127.0.0.1:3001/webhook
EVO_WEBHOOK_URL=http://host.docker.internal:3003/webhook

# Secret para validar que os webhooks vêm da Evolution API (opcional mas recomendado)
# Qualquer string aleatória longa — defina o mesmo valor em secretToken no webhook da Evolution
EVO_WEBHOOK_SECRET=

# ============================================================
# BANCO DE DADOS PostgreSQL
# ============================================================
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
# Exemplo local:      postgresql://maestro:senha123@localhost:5432/maestro360
# Exemplo Docker:     postgresql://maestro:senha123@postgres:5432/maestro360
# Exemplo produção:   postgresql://maestro:senha123@vps.seudominio.com:5432/maestro360
DATABASE_URL=postgresql://maestro:SENHA_AQUI@localhost:5432/maestro360

# Ativar SSL para conexões em produção (ex: Supabase, RDS, etc.)
DATABASE_SSL=false
